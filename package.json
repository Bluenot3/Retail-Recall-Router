{
  "name": "retail-recall-router",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "prepare:ocr": "node scripts/prepare-ocr-assets.mjs",
    "dev": "node scripts/prepare-ocr-assets.mjs && vite --host 0.0.0.0",
    "build": "node scripts/prepare-ocr-assets.mjs && tsc -b && vite build",
    "preview": "node scripts/prepare-ocr-assets.mjs && vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "1.0.0",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "7.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
